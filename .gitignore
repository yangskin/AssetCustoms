# Unreal Engine plugin ignores
Binaries/
Intermediate/
Saved/
DerivedDataCache/

# Build artifacts (optional for plugins)
Build/

# OS/editor
.DS_Store
Thumbs.db
*.log

# IDEs
.vscode/
.vs/
.idea/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.venv
.pytest_cache/

# Installed dependencies (generated by deploy.ps1, not committed)
# Packages are deployed directly into Content/Python/
Content/Python/PIL/
Content/Python/pillow*.dist-info/
Content/Python/PySide6/
Content/Python/PySide6_Essentials*.dist-info/
Content/Python/shiboken6/
Content/Python/shiboken6*.dist-info/
Content/Python/psd_tools/
Content/Python/psd_tools*.dist-info/
Content/Python/attrs/
Content/Python/attrs*.dist-info/
Content/Python/typing_extensions*/
Content/Python/numpy/
Content/Python/numpy-*.dist-info/
Content/Python/numpy.libs/
Content/Python/psd_tools.libs
Content/Python/attr
Content/Python/bin

# Misc
*.tmp
~$*

# ---> UnrealEngine
# Visual Studio 2015 user specific files

# Compiled Object files
*.slo
*.lo
*.o
*.obj

# Precompiled Headers
*.gch
*.pch

# Compiled Dynamic libraries
*.so
*.dylib
*.dll

# Fortran module files
*.mod

# Compiled Static libraries
*.lai
*.la
*.a
*.lib

# Executables
*.exe
*.out
*.app
*.ipa

# These project files can be generated by the engine
*.xcodeproj
*.xcworkspace
*.sln
*.suo
*.opensdf
*.sdf
*.VC.db
*.VC.opendb

# Precompiled Assets
SourceArt/**/*.png
SourceArt/**/*.tga

# Binary Files
Binaries/*
Plugins/**/Binaries/*

# Builds
Build/*

# Whitelist PakBlacklist-<BuildConfiguration>.txt files
!Build/*/
Build/*/**
!Build/*/PakBlacklist*.txt

# Don't ignore icon files in Build
!Build/**/*.ico

# Built data for maps
*_BuiltData.uasset

# Configuration files generated by the Editor
Saved/*

# Compiled source files for the engine to use
Intermediate/*
Plugins/**/Intermediate/*

# Cache files for the editor to use
DerivedDataCache/*
